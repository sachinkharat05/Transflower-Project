PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=transflower

# Set to true to start the server without MySQL (pages load; /api/* returns 503 except /api/health):
# DB_SKIP=true

# For npm run db:setup-user only — your MySQL admin (usually root):
# DB_ADMIN_USER=root
# DB_ADMIN_PASSWORD=your_mysql_admin_password

# App connection (after create-user.sql or db:setup-user):
DB_USER=transflower_user
DB_PASSWORD=transflower123

# Or use an existing local MySQL admin account for development:
# DB_USER=root
# DB_PASSWORD=your_root_password
